{
  "expo": {
    "name": "Beep Velozz",
    "slug": "beep-velozz",
    "version": "2.0.0",
    "jsEngine": "hermes",
    "platforms": ["ios", "android", "web"],
    "userInterfaceStyle": "automatic",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "splash": {
            "imageWidth": 200,
            "imageHeight": 200,
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
          },
          "platform": {
            "ios": {
              "splashImage": "./assets/images/splash-icon.png",
              "backgroundColor": "#ffffff",
              "imageWidth": 200,
              "imageHeight": 200,
              "resizeMode": "contain"
            },
            "android": {
              "splash": {
                "image": "./assets/images/splash-icon.png",
                "backgroundColor": "#ffffff",
                "resizeMode": "contain",
                "imageWidth": 200,
                "imageHeight": 200
              }
            }
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": ["**/*"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c8f82da-9e01-4276-a3ee-1d413458d4d4"
      },
      "sentry": {
        "org": "igaonamikaze",
        "project": "beep-velozz"
      },
      "firebaseApiKey": "AIzaSyAqS_rWdY5yhXwBLXL48Nooc-xfHpi5f5c",
      "firebaseAuthDomain": "beepvelozz.firebaseapp.com",
      "firebaseProjectId": "beepvelozz",
      "firebaseStorageBucket": "beepvelozz.firebasestorage.app",
      "firebaseMessagingSenderId": "418888118827",
      "firebaseAppId": "1:418888118827:web:155021bed2f6cf095c706e",
      "measurementId": "G-PVB66RW3B7"
    },
    "owner": "shopiii2025"
  }
}
